        {
          "source_range": "Gi2/0/1-48",
          "target_range": "Te2/0/1-48",
          "role": "access"
        }
      ],
      "uplink_rules": [
        {
          "source_ports": ["Gi2/0/49", "Gi2/0/50", "Gi2/0/51", "Gi2/0/52"],
          "target_ports": ["Te2/1/1", "Te2/1/2", "Te2/1/7", "Te2/1/8"],
